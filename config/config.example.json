{
  "agents": {
    "defaults": {
      "name": "picoclaw",
      "workspace": "~/.picoclaw/workspace",
      "restrict_to_workspace": true,
      "model": "",                // Optional: defaults to provider-specific model or "glm-4.7"
      "max_tokens": 0,           // Optional: 0 means use provider default (e.g. 8192)
      "temperature": 0,          // Optional: 0 means use provider default (e.g. 0.7)
      "max_tool_iterations": 0,  // Optional: 0 means use provider default (e.g. 20)
      "timeout": 0,              // Optional: 0 means use provider default (e.g. 120s)
      "subagent": {
        "max_iterations": 10,
        "max_depth": 5,
        "max_tokens": 8192,
        "temperature": 0.7
      }
    }
  },
  "workspaces": {
    "one": {
      "path": "~/.picoclaw/workspace_one",
      "users": ["discord_id_one", "telegram_id_one"],
      "restrict_to_workspace": true
    },
    "two": {
      "path": "~/.picoclaw/workspace_two",
      "users": ["discord_id_two"],
      "restrict_to_workspace": true,
      "allowed_external_paths": ["/tmp/shared", "C:/data/assets"]
    }
  },
  "model_list": [
    {
      "model_name": "gpt4",
      "model": "openai/gpt-5.2",
      "api_key": "sk-your-openai-key",
      "api_base": "https://api.openai.com/v1"
    },
    {
      "model_name": "claude-sonnet-4.6",
      "model": "anthropic/claude-sonnet-4.6",
      "api_key": "sk-ant-your-key",
      "api_base": "https://api.anthropic.com/v1"
    },
    {
      "model_name": "gemini",
      "model": "antigravity/gemini-2.0-flash",
      "auth_method": "oauth"
    },
    {
      "model_name": "deepseek",
      "model": "deepseek/deepseek-chat",
      "api_key": "sk-your-deepseek-key"
    },
    {
      "model_name": "loadbalanced-gpt4",
      "model": "openai/gpt-5.2",
      "api_key": "sk-key1",
      "api_base": "https://api1.example.com/v1"
    },
    {
      "model_name": "loadbalanced-gpt4",
      "model": "openai/gpt-5.2",
      "api_key": "sk-key2",
      "api_base": "https://api2.example.com/v1"
    }
  ],
  "channels": {
    "telegram": {
      "enabled": false,
      "token": "YOUR_TELEGRAM_BOT_TOKEN",
      "proxy": "",
      "allow_from": [
        "YOUR_USER_ID"
      ]
    },
    "discord": {
      "enabled": false,
      "token": "YOUR_DISCORD_BOT_TOKEN",
      "allow_from": []
    },
    "maixcam": {
      "enabled": false,
      "host": "0.0.0.0",
      "port": 18790,
      "allow_from": []
    },
    "whatsapp": {
      "enabled": false,
      "bridge_url": "ws://localhost:3001",
      "allow_from": []
    },
    "feishu": {
      "enabled": false,
      "app_id": "",
      "app_secret": "",
      "encrypt_key": "",
      "verification_token": "",
      "allow_from": []
    },
    "dingtalk": {
      "enabled": false,
      "client_id": "YOUR_CLIENT_ID",
      "client_secret": "YOUR_CLIENT_SECRET",
      "allow_from": []
    },
    "slack": {
      "enabled": false,
      "bot_token": "xoxb-YOUR-BOT-TOKEN",
      "app_token": "xapp-YOUR-APP-TOKEN",
      "allow_from": []
    },
    "line": {
      "enabled": false,
      "channel_secret": "YOUR_LINE_CHANNEL_SECRET",
      "channel_access_token": "YOUR_LINE_CHANNEL_ACCESS_TOKEN",
      "webhook_host": "0.0.0.0",
      "webhook_port": 18791,
      "webhook_path": "/webhook/line",
      "allow_from": []
    },
    "onebot": {
      "enabled": false,
      "ws_url": "ws://127.0.0.1:3001",
      "access_token": "",
      "reconnect_interval": 5,
      "group_trigger_prefix": [],
      "allow_from": []
    }
  },
  "providers": {
    "_comment": "DEPRECATED: Use model_list instead. This will be removed in a future version",
    "anthropic": {
      "model": "claude-3-5-sonnet-latest",
      "api_key": "",
      "api_base": ""
    },
    "openai": {
      "model": "gpt-4o",
      "api_key": "",
      "api_base": "",
      "max_tokens": 16384,
      "temperature": 1.0,
      "timeout": 300,
      "max_concurrent_sessions": 1,
      "web_search": true
    },
    "openrouter": {
      "api_key": "sk-or-v1-xxx",
      "api_base": ""
    },
    "groq": {
      "api_key": "gsk_xxx",
      "api_base": ""
    },
    "zhipu": {
      "api_key": "YOUR_ZHIPU_API_KEY",
      "api_base": ""
    },
    "gemini": {
      "api_key": "",
      "api_base": ""
    },
    "vllm": {
      "api_key": "",
      "api_base": ""
    },
    "nvidia": {
      "api_key": "nvapi-xxx",
      "api_base": "",
      "proxy": "http://127.0.0.1:7890"
    },
    "moonshot": {
      "api_key": "sk-xxx",
      "api_base": ""
    },
    "qwen": {
      "api_key": "sk-xxx",
      "api_base": ""
    },
    "ollama": {
      "llama": {
        "model": "llama3.2",
        "api_key": "",
        "api_base": "http://localhost:11434/v1"
      },
      "gpt-oss": {
        "model": "gpt-oss-120b",
        "api_key": "",
        "api_base": "http://localhost:1234/v1"
      },
      "llama3:70b": {
        "model": "llama3:70b",
        "api_base": "http://localhost:11434"
      }
    },
    // Schedule Provider Configuration
    // Supports both singleton object and multi-instance map format.
    "schedule": {
      // Example 1: Work Schedule (accessed via "provider": "schedule/work")
      "work": {
        "timezone": "America/New_York",
        "rules": [
          {
            "days": ["mon", "tue", "wed", "thu", "fri"],
            "hours": { "start": "09:00", "end": "17:00" },
            "provider": "anthropic",
            "model": "claude-3-5-sonnet-20240620"
          }
        ],
        "default": {
          "provider": "openai",
          "model": "gpt-4o-mini"
        }
      },
      // Example 2: Personal Schedule (accessed via "provider": "schedule/personal")
      "personal": {
        "timezone": "America/Los_Angeles",
        "rules": [
          {
            "days": ["weekend"],
            "provider": "ollama",
            "model": "llama3"
          }
        ],
        "default": {
          "provider": "groq",
          "model": "llama3-70b-8192"
        }
      }
    },
    // Overflow Provider Configuration
    // Allows chaining providers for failover when concurrency limits are reached.
    "overflow": {
      "default": {
        "list": ["ollama/llama3", "openrouter"]
      },
      "premium": {
        "list": ["openai", "anthropic"]
      }
    },
    "cerebras": {
      "api_key": "",
      "api_base": ""
    },
    "volcengine": {
      "api_key": "",
      "api_base": ""
    }
  },
  "tools": {
    "web": {
      "brave": {
        "enabled": false,
        "api_key": "YOUR_BRAVE_API_KEY",
        "max_results": 5
      },
      "duckduckgo": {
        "enabled": true,
        "max_results": 5
      },
      "searxng": {
        "enabled": false,
        "base_url": "http://localhost:8080",
        "max_results": 5

      },
      "perplexity": {
        "enabled": false,
        "api_key": "pplx-xxx",
        "max_results": 5
      }
    },
    "cron": {
      "exec_timeout_minutes": 5
    }
  },
  "heartbeat": {
    "enabled": true,
    "interval": 30
  },
  "devices": {
    "enabled": false,
    "monitor_usb": true
  },
  "memory": {
    "enabled": false,
    "provider": "qdrant",
    "qdrant": {
      "url": "http://localhost:6333",
      "collection_name": "picoclaw",
      "api_key": ""
    },
    "embedding": {
      "provider": "openai",
      "model": "text-embedding-3-small",
      "base_url": "https://api.openai.com/v1",
      "api_key": "YOUR_OPENAI_API_KEY",
      "timeout": 120
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790
  }
}
